library(cmdstanr)
weibull_model <- cmdstan_model('fit_weibull.stan')
stan_weibull_normal<-"
// This Stan program defines a model with a
// vector of values 'y' modeled as Weibull distributed
// with shape alpha > 0 and scale sigma > 0.
// Note this is the same parameterization given on Wikipedia
// https://en.wikipedia.org/wiki/Weibull_distribution
// except that on Wikipedia, shape is called k and scale is called lambda.
data {
int<lower=0> N;
vector[N] y;
}
parameters {
real<lower=0> alpha;
real<lower=0> sigma;
}
model {
// I'm not sure if the priors on alpha and sigma are reasonable for your stuff.
alpha ~ lognormal(1, 1);
sigma ~ lognormal(1, 1);
y ~ weibull(alpha, sigma);
}
"
